# Copy to .env.local and fill in. Never commit .env.local.

# Required for live TinyFish agent runs (server-side only)
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# Optional: browser profile for agents (lite | stealth)
# TINYFISH_BROWSER_PROFILE=stealth

# Async agent timeout (ms) — default 720000 (12m). Per-agent wall clock when polling run-async.
# TINYFISH_AGENT_TIMEOUT_MS=720000

# Poll interval for GET /v1/runs/{id} (ms), default 4000
# TINYFISH_POLL_INTERVAL_MS=4000

# Set to true to use /run-sse instead of run-async + poll
# TINYFISH_USE_SSE=false

# Optional: OpenAI for JSON synthesis after extraction (server-side only)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
